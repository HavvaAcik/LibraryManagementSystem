@model LibraryManagementSystem.Models.Author

@{
    ViewData["Title"] = "Details";
}

<h1>Detaylar</h1>

<div>
    <h4>Yazarlar</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.AuthorFullName)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.AuthorFullName)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.BirthYear)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.BirthYear)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Biography)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Biography)
        </dd>
    </dl>
</div>
<div class="mt-4">
    <a asp-action="Edit" asp-route-id="@Model?.AuthorId" class="btn btn-library-green shadow-sm px-4">Düzenle</a>

    <a asp-action="Index" class="btn btn-library-outline shadow-sm ms-2 px-4">Listeye Geri Dön</a>
</div>
