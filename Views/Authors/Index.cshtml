@model IEnumerable<LibraryManagementSystem.Models.Author>
@{
    ViewData["Title"] = "Yazarlar";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Yazarlar</h1>
    <a asp-action="Create" class="btn btn-library-green shadow-sm">Yeni Yazar Ekle</a>
</div>

<table class="table table-hover shadow-sm">
    <thead style="background-color: #ECF0EC;">
        <tr>
            <th>@Html.DisplayNameFor(model => model.AuthorFullName)</th>
            <th>@Html.DisplayNameFor(model => model.BirthYear)</th>
            <th>@Html.DisplayNameFor(model => model.Biography)</th>
            <th class="text-center">İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.AuthorFullName)</td>
                <td>@Html.DisplayFor(modelItem => item.BirthYear)</td>
                <td>@Html.DisplayFor(modelItem => item.Biography)</td>
                <td class="text-center">
                    <div class="btn-group shadow-sm" role="group">
                        <a asp-action="Edit" asp-route-id="@item.AuthorId" class="btn btn-sm btn-library-outline">Düzenle</a>
                        <a asp-action="Details" asp-route-id="@item.AuthorId" class="btn btn-sm btn-library-outline">Detaylar</a>
                        <a asp-action="Delete" asp-route-id="@item.AuthorId" class="btn btn-sm btn-danger text-white">Sil</a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>