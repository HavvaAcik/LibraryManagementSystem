@model LibraryManagementSystem.Models.Author

@{
    ViewData["Title"] = "Yeni Yazar";
}

<div class="card-custom p-4 shadow-sm">
    <h1 class="mb-4">Yeni Yazar Ekle</h1>
    <hr />

    <div class="row">
        <div class="col-md-8">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group mb-3">
                    <label asp-for="AuthorFullName" class="control-label fw-bold"></label>
                    <input asp-for="AuthorFullName" class="form-control shadow-sm" placeholder="Ad Soyad giriniz..." />
                    <span asp-validation-for="AuthorFullName" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="BirthYear" class="control-label fw-bold"></label>
                    <input asp-for="BirthYear" type="number" class="form-control shadow-sm" />
                    <span asp-validation-for="BirthYear" class="text-danger"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="Biography" class="control-label fw-bold"></label>
                    <textarea asp-for="Biography" class="form-control shadow-sm" rows="4" placeholder="Kısa biyografi..."></textarea>
                    <span asp-validation-for="Biography" class="text-danger"></span>
                </div>

                <div class="form-group d-flex align-items-center">
                    <input type="submit" value="Yazarı Kaydet" class="btn btn-library-green shadow me-3" />
                    <a asp-action="Index" class="btn btn-library-outline shadow-sm">Listeye Geri Dön</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}