@model LibraryManagementSystem.Models.Loan

<div class="container text-center py-5">
    <h2 class="text-danger mb-4"><i class="bi bi-trash"></i> İşlemi Sil</h2>
    <p class="text-muted">Bu ödünç alma kaydını sistemden kalıcı olarak silmek istediğinize emin misiniz?</p>
    
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="p-4 mb-4 rounded-4" style="background-color: var(--primary-100); border: 1px dashed var(--primary-500);">
                <h5 class="fw-bold">@Model.Book.Title</h5>
                <p class="mb-0 text-secondary">@Model.Student.StudentFullName tarafından alınmıştı.</p>
                <small class="text-muted">Tarih: @Model.LoanDate.ToShortDateString()</small>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="LoanId" />
                <div class="d-flex justify-content-center gap-3">
                    <button type="submit" class="btn btn-danger px-5">Evet, Sil</button>
                    <a asp-action="Index" class="btn btn-secondary px-5">Vazgeç</a>
                </div>
            </form>
        </div>
    </div>
</div>v