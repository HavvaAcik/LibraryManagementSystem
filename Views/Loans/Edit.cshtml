@model LibraryManagementSystem.Models.Loan

<div class="row justify-content-center py-4">
    <div class="col-md-6">
        <h3 class="mb-4" style="color: var(--primary-700); font-weight: 600;">
            <i class="bi bi-pencil-square"></i> Ödünç Kaydını Güncelle
        </h3>

        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="LoanId" />

            <div class="mb-3">
                <label class="form-label fw-bold">Öğrenci</label>
                <select asp-for="StudentId" class="form-select shadow-sm" asp-items="ViewBag.StudentId" style="border-radius: 8px;"></select>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Kitap</label>
                <select asp-for="BookId" class="form-select shadow-sm" asp-items="ViewBag.BookId" style="border-radius: 8px;"></select>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="LoanDate" class="form-label fw-bold"></label>
                    <input asp-for="LoanDate" class="form-control shadow-sm" type="date" style="border-radius: 8px;" />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="ReturnDate" class="form-label fw-bold"></label>
                    <input asp-for="ReturnDate" class="form-control shadow-sm" type="date" style="border-radius: 8px;" />
                </div>
            </div>

            <div class="form-check mb-4 mt-2">
                <input class="form-check-input" type="checkbox" asp-for="IsReturned" id="isReturnedCheck">
                <label class="form-check-label fw-bold" for="isReturnedCheck">
                    Kitap İade Edildi mi?
                </label>
            </div>

            <div class="mt-4 border-top pt-3 d-flex gap-2">
                <button type="submit" class="btn btn-library-green px-5 shadow-sm">Değişiklikleri Kaydet</button>
                <a asp-action="Index" class="btn btn-outline-secondary px-4">Listeye Dön</a>
            </div>
        </form>
    </div>
</div>