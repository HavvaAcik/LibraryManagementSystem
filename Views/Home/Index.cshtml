@{
    ViewData["Title"] = "Ana Sayfa";
    var recentBooks = ViewBag.RecentBooks as List<LibraryManagementSystem.Models.Book>;
    var overdueList = ViewBag.OverdueList as List<LibraryManagementSystem.Models.Loan>;
}

@* Gecikme Uyarı Banner'ı *@
@if (overdueList != null && overdueList.Any())
{
    <div class="alert alert-danger d-flex align-items-center mb-4 shadow-sm" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
        <div>
            <strong>@overdueList.Count adet kitap</strong> 15 günü aşmış ve henüz iade edilmemiş!
            <a asp-controller="Loans" asp-action="Index" class="alert-link ms-2">Listeye Git →</a>
        </div>
    </div>
}

@* Genel İstatistikler *@
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="p-3 rounded-3 shadow-sm text-center" style="background-color: var(--primary-100);">
            <div class="fs-2 fw-bold" style="color: var(--primary-700);">@ViewBag.TotalBooks</div>
            <div class="text-muted small"><i class="bi bi-book me-1"></i> Toplam Kitap</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="p-3 rounded-3 shadow-sm text-center" style="background-color: var(--primary-100);">
            <div class="fs-2 fw-bold" style="color: var(--primary-700);">@ViewBag.TotalStudents</div>
            <div class="text-muted small"><i class="bi bi-people me-1"></i> Toplam Öğrenci</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="p-3 rounded-3 shadow-sm text-center" style="background-color: var(--primary-100);">
            <div class="fs-2 fw-bold" style="color: var(--primary-700);">@ViewBag.TotalAuthors</div>
            <div class="text-muted small"><i class="bi bi-person-lines-fill me-1"></i> Toplam Yazar</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="p-3 rounded-3 shadow-sm text-center" style="background-color: var(--primary-100);">
            <div class="fs-2 fw-bold" style="color: var(--primary-700);">@ViewBag.TotalCategories</div>
            <div class="text-muted small"><i class="bi bi-tag me-1"></i> Toplam Kategori</div>
        </div>
    </div>
</div>

@* Ödünç İstatistikleri *@
<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="p-3 rounded-3 shadow-sm text-center text-white" style="background-color: var(--primary-500);">
            <div class="fs-2 fw-bold">@ViewBag.ActiveLoans</div>
            <div class="small"><i class="bi bi-hourglass-split me-1"></i> Aktif Ödünç</div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="p-3 rounded-3 shadow-sm text-center" style="background-color: #f8d7da;">
            <div class="fs-2 fw-bold text-danger">@ViewBag.OverdueLoans</div>
            <div class="small text-muted"><i class="bi bi-exclamation-triangle me-1"></i> Gecikmiş Kitap</div>
        </div>
    </div>
</div>

@* Son Eklenen Kitaplar *@
<h5 class="fw-bold mb-3" style="color: var(--primary-700);">
    <i class="bi bi-clock-history me-2"></i> Son Eklenen Kitaplar
</h5>

@if (recentBooks != null && recentBooks.Any())
{
    <div class="row row-cols-1 row-cols-md-4 g-3">
        @foreach (var book in recentBooks)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden">
                    <div style="height: 180px; background-color: #f8f9fa;">
                        @if (!string.IsNullOrEmpty(book.ImageUrl))
                        {
                            <img src="@book.ImageUrl" class="w-100 h-100"
                                 style="object-fit: contain; padding: 10px;" alt="@book.Title" />
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center h-100 text-muted">
                                <i class="bi bi-image fs-2"></i>
                            </div>
                        }
                    </div>
                    <div class="card-body p-3">
                        <h6 class="fw-bold text-truncate mb-1" title="@book.Title">@book.Title</h6>
                        <p class="text-muted small mb-0">
                            <i class="bi bi-person-fill me-1"></i> @book.Author?.AuthorFullName
                        </p>
                        <p class="text-muted small mb-2">
                            <i class="bi bi-tag me-1"></i> @book.Category?.CategoryName
                        </p>
                        <a asp-controller="Books" asp-action="Details" asp-route-id="@book.BookId"
                           class="btn btn-sm btn-library-outline w-100 rounded-pill">
                            Detaylar
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info shadow-sm">
        <i class="bi bi-info-circle me-2"></i>
        Henüz kitap eklenmemiş.
    </div>
}