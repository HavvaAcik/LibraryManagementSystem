@model IEnumerable<LibraryManagementSystem.Models.Book>
@{
    ViewData["Title"] = "Kitap Listesi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Kitaplar</h1>
    <a asp-action="Create" class="btn btn-library-green shadow-sm">Yeni Kitap Ekle</a>
</div>

<table class="table table-hover shadow-sm bg-white">
    <thead style="background-color: #ECF0EC;">
        <tr>
            <th>@Html.DisplayNameFor(model => model.Title)</th>
            <th>@Html.DisplayNameFor(model => model.ISBN)</th>
            <th>@Html.DisplayNameFor(model => model.PublishedYear)</th>
            <th>@Html.DisplayNameFor(model => model.Category)</th>
            <th>@Html.DisplayNameFor(model => model.Author)</th>
            <th class="text-center">İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td class="fw-bold">@Html.DisplayFor(modelItem => item.Title)</td>
                <td>@Html.DisplayFor(modelItem => item.ISBN)</td>
                <td>@Html.DisplayFor(modelItem => item.PublishedYear)</td>
                <td><span class="badge bg-light text-dark border">@Html.DisplayFor(modelItem => item.Category.CategoryName)</span></td>
                <td>@Html.DisplayFor(modelItem => item.Author.AuthorFullName)</td>
                <td class="text-center">
                    <div class="btn-group shadow-sm" role="group">
                        <a asp-action="Edit" asp-route-id="@item.BookId" class="btn btn-sm btn-library-outline">Düzenle</a>
                        <a asp-action="Details" asp-route-id="@item.BookId" class="btn btn-sm btn-library-outline">Detaylar</a>
                        <a asp-action="Delete" asp-route-id="@item.BookId" class="btn btn-sm btn-danger text-white">Sil</a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>