@model IEnumerable<LibraryManagementSystem.Models.Book>
@{
    ViewData["Title"] = "Kitap Listesi";
}

@* Başlık ve yeni ekle butonu  *@
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold text-dark">Kitaplar</h1>
    <a asp-action="Create" class="btn btn-library-green shadow-sm px-4 rounded-pill">
        <i class="bi bi-plus-lg"></i> Yeni Kitap Ekle
    </a>
</div>

@* arama çubuğu *@
<div class="row mb-5 justify-content-center">
    <div class="col-md-6">
        <form asp-action="Index" method="get" id="searchForm" class="input-group shadow-sm rounded-pill overflow-hidden border">
            <input type="text" id="bookSearch" name="searchString"
                   class="form-control border-0 ps-4"
                   placeholder="Kitap, yazar veya kategori ara..."
                   value="@ViewData["CurrentFilter"]"
                   style="height: 46px; outline: none; box-shadow: none;">
            <button class="btn btn-white border-0 px-3 text-muted" type="submit">
                <i class="bi bi-search"></i>
            </button>
        </form>
    </div>
</div>

@* Kitap kartlları *@
<div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
    @foreach (var item in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden bg-white transition-card">
                @* Kitap kapağı resmi *@
                <div class="position-relative" style="height: 250px; background-color: #f8f9fa;">
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" class="card-img-top w-100 h-100"
                             style="object-fit: contain; padding: 15px;" alt="@item.Title">
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center h-100 text-muted small italic">
                            <i class="bi bi-image me-2"></i> Görsel Yok
                        </div>
                    }
                    @* Yayın yılı *@
                    <span class="position-absolute top-0 end-0 badge bg-library-green m-3 shadow-sm">
                        @item.PublishedYear
                    </span>
                </div>

                @* Kart İçeriği *@
                <div class="card-body d-flex flex-column p-4">
                    <h5 class="card-title fw-bold text-dark text-truncate mb-1" title="@item.Title">
                        @item.Title
                    </h5>
                    <p class="card-text text-muted mb-2 small">
                        <i class="bi bi-person-fill text-library-green"></i> @item.Author.AuthorFullName
                    </p>
                    <div class="mb-3">
                        <span class="badge bg-light text-success border border-success-subtle rounded-pill px-3">
                            @item.Category.CategoryName
                        </span>
                    </div>

                    @* Özet (Maksimum 2 Satır) *@
                    <p class="card-text text-secondary small mb-4"
                       style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.5;">
                        @item.Summary
                    </p>

                    @* Alt İşlem Menüsü *@
                    <div class="mt-auto pt-3 border-top">
                        <div class="d-flex gap-2">
                            <a asp-action="Details" asp-route-id="@item.BookId"
                               class="btn btn-sm btn-library-outline flex-grow-1 rounded-pill fw-bold">
                                Detaylar
                            </a>
                            <div class="dropdown">
                                <button class="btn btn-sm btn-light border rounded-circle shadow-sm"
                                        type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-three-dots-vertical"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                                    <li>
                                        <a class="dropdown-item" asp-action="Edit" asp-route-id="@item.BookId">
                                            <i class="bi bi-pencil me-2"></i> Düzenle
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item text-danger" asp-action="Delete" asp-route-id="@item.BookId">
                                            <i class="bi bi-trash me-2"></i> Sil
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    @* JQuery UI ve Gerekli Kütüphaneler *@
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>

    <script>
        $(document).ready(function () {
            $("#bookSearch").autocomplete({
                source: function (request, response) {
                    $.ajax({
                        url: '@Url.Action("GetSuggestions", "Books")',
                        type: "GET",
                        data: { term: request.term },
                        success: function (data) {
                            response(data);
                        }
                    });
                },
                minLength: 1, // 1 harf yazınca başlar
                select: function (event, ui) {
                    // Seçim yapılınca inputu doldur ve formu gönder
                    $("#bookSearch").val(ui.item.value);
                    $("#searchForm").submit();
                }
            });
        });
    </script>
}

<style>
    .transition-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .transition-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }

    .btn-library-green {
        background-color: #5a8d6a;
        color: white;
    }

    .bg-library-green {
        background-color: #5a8d6a !important;
    }

    /* Otomatik Tamamlama Menüsü Stili */
    .ui-autocomplete {
        border-radius: 12px;
        box-shadow: 0 8px 16px rgba(0,0,0,0.1);
        border: 1px solid #eee;
        padding: 5px;
        z-index: 1000;
        max-height: 250px;
        overflow-y: auto;
    }

    .ui-menu-item {
        padding: 5px;
    }

    .ui-menu-item-wrapper {
        padding: 8px 15px !important;
        border-radius: 8px !important;
        border: none !important;
    }

    .ui-state-active, .ui-widget-content .ui-state-active {
        background-color: #5a8d6a !important;
        color: white !important;
    }
</style>