@model LibraryManagementSystem.Models.Book
@{
    ViewData["Title"] = "Kitap Detayları";
}

<h1>Kitap Detayları</h1>
<div class="shadow-sm p-4 bg-white rounded-3 mt-4">
    <dl class="row mb-0">
        <dt class="col-sm-3 fw-bold text-muted border-bottom py-2">Kitap Adı:</dt>
        <dd class="col-sm-9 fs-5 border-bottom py-2">@Html.DisplayFor(model => model.Title)</dd>

        <dt class="col-sm-3 fw-bold text-muted border-bottom py-2">ISBN:</dt>
        <dd class="col-sm-9 border-bottom py-2">@Html.DisplayFor(model => model.ISBN)</dd>

        <dt class="col-sm-3 fw-bold text-muted border-bottom py-2">Kategori:</dt>
        <dd class="col-sm-9 border-bottom py-2">@Html.DisplayFor(model => model.Category.CategoryName)</dd>

        <dt class="col-sm-3 fw-bold text-muted py-2">Yazar:</dt>
        <dd class="col-sm-9 py-2">@Html.DisplayFor(model => model.Author.AuthorFullName)</dd>
    </dl>
</div>
<div class="mt-4">
    <a asp-action="Edit" asp-route-id="@Model?.BookId" class="btn btn-library-green shadow-sm px-4">Düzenle</a>
    <a asp-action="Index" class="btn btn-library-outline shadow-sm ms-2 px-4">Listeye Dön</a>
</div>