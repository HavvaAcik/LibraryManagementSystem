@model IEnumerable<LibraryManagementSystem.Models.Student>
@{
    ViewData["Title"] = "Öğrenci Listesi";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Öğrenciler</h1>
    <a asp-action="Create" class="btn btn-library-green shadow-sm">Yeni Öğrenci Kaydı</a>
</div>
<table class="table table-hover shadow-sm">
    <thead style="background-color: #ECF0EC;">
        <tr>
            <th>@Html.DisplayNameFor(model => model.StudentFullName)</th>
            <th>@Html.DisplayNameFor(model => model.StudentNumber)</th>
            <th>@Html.DisplayNameFor(model => model.Department)</th>
            <th>@Html.DisplayNameFor(model => model.PhoneNumber)</th>
            <th class="text-center">İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.StudentFullName</td>
                <td>@item.StudentNumber</td>
                <td>@item.Department</td>
                <td>@item.PhoneNumber</td>
                <td class="text-center">
                    <div class="btn-group shadow-sm" role="group">
                        <a asp-action="Edit" asp-route-id="@item.StudentId" class="btn btn-sm btn-library-outline">Düzenle</a>
                        <a asp-action="Details" asp-route-id="@item.StudentId" class="btn btn-sm btn-library-outline">Detaylar</a>
                        <a asp-action="Delete" asp-route-id="@item.StudentId" class="btn btn-sm btn-danger text-white">Sil</a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>