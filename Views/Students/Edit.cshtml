@model LibraryManagementSystem.Models.Student

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h3 class="mb-4" style="color: var(--primary-700);">
                <i class="bi bi-pencil-square"></i> Öğrenci Bilgilerini Güncelle
            </h3>

            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="StudentId" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="StudentFullName" class="form-label fw-semibold"></label>
                        <input asp-for="StudentFullName" class="form-control" style="border-radius: 8px;" />
                        <span asp-validation-for="StudentFullName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="StudentNumber" class="form-label fw-semibold"></label>
                        <input asp-for="StudentNumber" class="form-control" style="border-radius: 8px;" />
                        <span asp-validation-for="StudentNumber" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Department" class="form-label fw-semibold"></label>
                        <input asp-for="Department" class="form-control" style="border-radius: 8px;" />
                        <span asp-validation-for="Department" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="PhoneNumber" class="form-label fw-semibold"></label>
                        <input asp-for="PhoneNumber" class="form-control" style="border-radius: 8px;" />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-4 border-top pt-3 d-flex gap-2">
                    <button type="submit" class="btn btn-custom-primary px-4">Değişiklikleri Kaydet</button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4" style="border-radius: 8px;">Vazgeç</a>
                </div>
            </form>
        </div>
    </div>
</div>