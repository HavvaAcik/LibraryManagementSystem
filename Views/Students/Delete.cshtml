@model LibraryManagementSystem.Models.Student

<div class="container text-center py-4">
    <div class="mb-4">
        <div class="display-5 text-muted mb-3">
            <i class="bi bi-person-x"></i>
        </div>
        <h3 style="color: var(--primary-700);">Kaydı Silmek İstiyor Musunuz?</h3>
        <p class="text-muted">Bu öğrenci kaydı kalıcı olarak sistemden kaldırılacaktır.</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="p-4 mb-4" style="background-color: var(--primary-50); border: 1px dashed var(--primary-500); border-radius: 12px;">
                <h5 class="mb-2">@Model.StudentFullName</h5>
                <p class="mb-1 text-secondary">Okul No: @Model.StudentNumber</p>
                <p class="mb-0 text-secondary">Bölüm: @Model.Department</p>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="StudentId" />
                <div class="d-flex justify-content-center gap-3">
                    <button type="submit" class="btn btn-danger px-5" style="border-radius: 8px;">Evet, Sil</button>
                    <a asp-action="Index" class="btn btn-secondary px-5" style="border-radius: 8px;">Vazgeç</a>
                </div>
            </form>
        </div>
    </div>
</div>