@model LibraryManagementSystem.Models.Category

@{
    ViewData["Title"] = "Kategori Düzenle";
}

<div class="card-custom p-4">
    <h1>Kategoriyi Düzenle</h1>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="CategoryId" />

                <div class="form-group mb-3">
                    <label asp-for="CategoryName" class="control-label fw-bold"></label>
                    <input asp-for="CategoryName" class="form-control shadow-sm" />
                    <span asp-validation-for="CategoryName" class="text-danger"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="CategoryDescription" class="control-label fw-bold"></label>
                    <textarea asp-for="CategoryDescription" class="form-control shadow-sm" rows="3"></textarea>
                    <span asp-validation-for="CategoryDescription" class="text-danger"></span>
                </div>

                <div class="form-group d-flex align-items-center">
                    <input type="submit" value="Değişiklikleri Kaydet" class="btn btn-library-green shadow me-3" />
                    <a asp-action="Index" class="btn btn-library-outline shadow-sm">Listeye Geri Dön</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}