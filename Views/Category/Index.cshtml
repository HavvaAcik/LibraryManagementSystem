@model IEnumerable<LibraryManagementSystem.Models.Category>

@{
    ViewData["Title"] = "Kategoriler";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Kategoriler</h1>
    <a asp-action="Create" class="btn btn-library-green">Yeni Kategori Ekle</a>
</div>

<table class="table table-hover shadow-sm">
    <thead style="background-color: #ECF0EC;">
        <tr>
            <th>@Html.DisplayNameFor(model => model.CategoryName)</th>
            <th>@Html.DisplayNameFor(model => model.CategoryDescription)</th>
            <th class="text-center">İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.CategoryName)</td>
                <td>@Html.DisplayFor(modelItem => item.CategoryDescription)</td>
                <td class="text-center">
                    <div class="btn-group shadow-sm" role="group">
                        <a asp-action="Edit" asp-route-id="@item.CategoryId" class="btn btn-sm btn-library-outline">Düzenle</a>
                        <a asp-action="Details" asp-route-id="@item.CategoryId" class="btn btn-sm btn-library-outline">Detaylar</a>
                        <a asp-action="Delete" asp-route-id="@item.CategoryId" class="btn btn-sm btn-danger text-white">Sil</a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>